{
	# Keep Caddy's administration API local to the VPS.
	admin 127.0.0.1:2019
	email {$ACME_EMAIL}

	# Slow-client and long-scan bounds. This template requires Caddy >= 2.10.0.
	servers {
		max_header_size 32KB
		timeouts {
			read_header 10s
			read_body 20m
			write 20m
			idle 2m
		}
	}
}

{$OBFUSCAN_DOMAIN} {
	encode zstd gzip

	log {
		output file logs/caddy-access.log {
			roll_size 100MiB
			roll_keep 10
			roll_keep_for 720h
		}
		format json
	}

	route {
		# Reject oversized requests at the edge before Python receives them.
		request_body {
			max_size 512MiB
		}

		# Fail closed: Caddy will not accept this block without a valid bcrypt hash.
		basic_auth {
			{$OBFUSCAN_BASIC_AUTH_USER} {$OBFUSCAN_BASIC_AUTH_HASH}
		}

		header {
			Strict-Transport-Security "max-age=31536000; includeSubDomains"
			X-Content-Type-Options "nosniff"
			X-Frame-Options "DENY"
			Referrer-Policy "no-referrer"
			Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
			Content-Security-Policy "default-src 'self'; base-uri 'none'; form-action 'self'; frame-ancestors 'none'; object-src 'none'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self'"
			-Server
		}

		# The backend is reachable only through loopback. Do not change to 0.0.0.0.
		reverse_proxy 127.0.0.1:8080 {
			transport http {
				dial_timeout 5s
				response_header_timeout 20m
				read_timeout 20m
				write_timeout 20m
			}
			health_uri /status
			health_interval 30s
			health_timeout 5s
		}
	}
}
